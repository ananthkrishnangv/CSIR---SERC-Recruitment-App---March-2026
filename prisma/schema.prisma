generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  role          String    @default("APPLICANT") // ADMIN, APPROVER, REVIEWER, APPLICANT
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       Profile?
  applications  Application[]
}

model Profile {
  id            String    @id @default(cuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  profilePicture String?
  dob           DateTime?
  gender        String?
  category      String?   // UR, SC, ST, OBC-NCL, EWS, PwBD
  pwd           Boolean   @default(false)
  pwdType       String?
  exServiceman  Boolean   @default(false)
  csirEmployee  Boolean   @default(false)
  phone         String?
  address       String?
  city          String?
  state         String?
  pincode       String?
  educationDetails  String? // JSON
  experienceDetails String? // JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Job {
  id            String    @id @default(cuid())
  title         String
  code          String    @unique
  description   String
  department    String
  lab           String    @default("CSIR-SERC")
  maxAge        Int       // Base max age for UR
  vacancies     Int       @default(1) // Total vacancies
  openDate      DateTime
  closeDate     DateTime
  crucialDate   DateTime  // Date for age/qualification calculation
  status        String    @default("OPEN") // DRAFT, OPEN, CLOSED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reservations  JobReservation[]
  applications  Application[]
}

model JobReservation {
  id            String    @id @default(cuid())
  jobId         String
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  category      String    // UR, SC, ST, OBC-NCL, EWS, PwBD
  vacancies     Int       @default(0)
  ageRelaxation Int       @default(0) // e.g., 5 for SC/ST, 3 for OBC
  
  @@unique([jobId, category])
}

model Application {
  id            String    @id @default(cuid())
  applicationNo String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status        String    @default("DRAFT") // DRAFT, SUBMITTED, UNDER_REVIEW, SHORTLISTED_FOR_TEST, PENDING_DIRECTOR_APPROVAL, APPROVED_BY_DIRECTOR, REJECTED, SELECTED
  step          Int       @default(1)
  
  // JSON fields to store the 7-step data
  personalDetails     String? // JSON
  educationDetails    String? // JSON
  experienceDetails   String? // JSON
  documentDetails     String? // JSON
  paymentDetails      String? // JSON
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  auditLogs     AuditLog[]
  
  @@unique([userId, jobId])
}

model AuditLog {
  id            String    @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  action        String
  performedBy   String    // User ID
  notes         String?
  createdAt     DateTime  @default(now())
}
