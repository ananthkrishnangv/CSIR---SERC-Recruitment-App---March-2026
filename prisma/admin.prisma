generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/admin-client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./admin.db"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?  // Can store JSON or base64 data
  updatedAt DateTime @updatedAt
}
